<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cimcum · Tikun — trzy ruchy światła</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;1,300&family=Spectral:wght@200;300&display=swap" rel="stylesheet">
<style>
  :root{ --ink:#05060c; --gold:#e8b657; --pale:#f6ead0; }
  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{height:100%;background:var(--ink);overflow:hidden;cursor:crosshair;}
  canvas{display:block;position:fixed;inset:0;}

  .overlay{
    position:fixed;inset:0;pointer-events:none;
    display:flex;flex-direction:column;justify-content:space-between;
    padding:clamp(20px,4.5vw,56px);z-index:2;
  }
  .top{display:flex;flex-direction:column;gap:.35em;}
  .kicker{
    font-family:'Spectral',serif;font-weight:200;
    letter-spacing:.6em;text-transform:uppercase;
    font-size:clamp(8px,1.05vw,11px);
    color:rgba(246,234,208,.42);padding-left:.6em;
  }
  h1{
    font-family:'Cormorant',serif;font-weight:300;font-style:italic;
    font-size:clamp(34px,7.6vw,92px);line-height:.92;color:var(--pale);
    text-shadow:0 0 38px rgba(232,182,87,.22);
  }
  .bottom{display:flex;justify-content:space-between;align-items:flex-end;gap:24px;flex-wrap:wrap;}
  .gloss{
    font-family:'Cormorant',serif;font-weight:300;
    font-size:clamp(14px,1.9vw,21px);line-height:1.5;
    color:rgba(246,234,208,.66);max-width:36ch;
    transition:opacity .9s ease;
  }
  .gloss em{color:var(--gold);font-style:italic;}

  .controls{
    pointer-events:auto;display:flex;flex-direction:column;gap:14px;
    align-items:flex-end;text-align:right;
  }
  .modes{display:flex;gap:0;border:1px solid rgba(246,234,208,.16);border-radius:2px;overflow:hidden;}
  .modes button{
    background:transparent;border:0;cursor:pointer;
    font-family:'Spectral',serif;font-weight:300;
    font-size:clamp(10px,1.1vw,12px);letter-spacing:.18em;
    color:rgba(246,234,208,.4);padding:9px 16px;
    transition:all .5s ease;
  }
  .modes button + button{border-left:1px solid rgba(246,234,208,.16);}
  .modes button.on{color:var(--ink);background:var(--gold);box-shadow:0 0 26px rgba(232,182,87,.4);}
  .meta{display:flex;gap:18px;align-items:center;}
  .meta button{
    background:transparent;border:0;cursor:pointer;
    font-family:'Spectral',serif;font-weight:300;
    font-size:clamp(10px,1.1vw,12px);letter-spacing:.16em;
    color:rgba(246,234,208,.34);transition:color .4s ease;
  }
  .meta button:hover{color:var(--gold);}
  .meta button.live{color:var(--gold);}
  @media (max-width:620px){ .gloss{max-width:24ch;} .bottom{align-items:flex-start;} }
</style>
</head>
<body>
<canvas id="c"></canvas>
<div class="overlay">
  <div class="top">
    <span class="kicker">cimcum · szewira · tikun</span>
    <h1>Trzy ruchy<br>światła</h1>
  </div>
  <div class="bottom">
    <p class="gloss" id="gloss">Najpierw światło się <em>wycofuje</em>. Tam, gdzie dotkniesz, otwiera się pustka — i dopiero ona nadaje kształt temu, co widać.</p>
    <div class="controls">
      <div class="modes">
        <button id="mWith" class="on" data-mode="withdraw">צמצום · cofnięcie</button>
        <button id="mMend" data-mode="mend">תיקון · naprawa</button>
      </div>
      <div class="meta">
        <button id="snd">♪ dźwięk</button>
        <button id="reseed">↻ od nowa</button>
      </div>
    </div>
  </div>
</div>
<script>
const cv=document.getElementById('c');
const ctx=cv.getContext('2d',{alpha:false});
let W,H,DPR;
function resize(){
  DPR=Math.min(window.devicePixelRatio||1,2);
  W=innerWidth;H=innerHeight;
  cv.width=W*DPR;cv.height=H*DPR;
  cv.style.width=W+'px';cv.style.height=H+'px';
  ctx.setTransform(DPR,0,0,DPR,0,0);
  ctx.fillStyle='#05060c';ctx.fillRect(0,0,W,H);
}
resize();addEventListener('resize',resize);

/* ---- value-noise flow field ---- */
const perm=new Uint8Array(512);
(function(){const p=[];for(let i=0;i<256;i++)p[i]=i;
 for(let i=255;i>0;i--){const j=(Math.random()*(i+1))|0;[p[i],p[j]]=[p[j],p[i]];}
 for(let i=0;i<512;i++)perm[i]=p[i&255];})();
const fade=t=>t*t*t*(t*(t*6-15)+10), lerp=(a,b,t)=>a+(b-a)*t;
function grad(h,x,y){switch(h&3){case 0:return x+y;case 1:return -x+y;case 2:return x-y;default:return -x-y;}}
function noise(x,y){
  const X=Math.floor(x)&255,Y=Math.floor(y)&255;x-=Math.floor(x);y-=Math.floor(y);
  const u=fade(x),v=fade(y);
  const aa=perm[perm[X]+Y],ab=perm[perm[X]+Y+1],ba=perm[perm[X+1]+Y],bb=perm[perm[X+1]+Y+1];
  return lerp(lerp(grad(aa,x,y),grad(ba,x-1,y),u),lerp(grad(ab,x,y-1),grad(bb,x-1,y-1),u),v);
}

/* ---- state ---- */
let mode='withdraw';
const wells=[];
const sparks=[];
const SPARK_CAP=900;
let bloom=0;                       // warm swell when light is redeemed
const pointer={x:-999,y:-999,active:false};
let lastWell=0;
let t=0;
let whole=false, wholeGlow=0;
const NS=0.0016, TS=0.10;

function seedWell(x,y,r){wells.push({x,y,r,r0:r,born:performance.now(),life:0});}
function autoSeed(){
  wells.length=0; whole=false;
  const n=3+(Math.random()*2|0);
  for(let i=0;i<n;i++)
    seedWell(W*(0.2+Math.random()*0.6),H*(0.2+Math.random()*0.6),Math.min(W,H)*(0.07+Math.random()*0.11));
}
autoSeed();

function addSpark(x,y){
  if(sparks.length>=SPARK_CAP)return;
  sparks.push({x,y,vx:(Math.random()-0.5)*0.4,vy:(Math.random()-0.5)*0.4,
    a:0.55+Math.random()*0.4, span:900+Math.random()*1400, age:0});
}

/* ---- particles ---- */
const N=Math.round(Math.min(2600,Math.max(900,(W*H)/780)));
const P=[];
function spawn(p){p.x=Math.random()*W;p.y=Math.random()*H;p.px=p.x;p.py=p.y;p.age=0;
  p.span=140+Math.random()*340;p.spd=0.6+Math.random()*1.1;p.warm=Math.random();}
for(let i=0;i<N;i++){const p={};spawn(p);p.age=Math.random()*p.span;P.push(p);}

function step(){
  t++;
  const now=performance.now();
  wholeGlow+=((whole?1:0)-wholeGlow)*0.02;

  // wells breathe + shed sparks (shevirat ha-kelim)
  for(let i=wells.length-1;i>=0;i--){
    const w=wells[i];w.life=(now-w.born)/1000;
    w.r=w.r0*(1+0.06*Math.sin(w.life*1.3+i));
    if(Math.random()<0.05){
      const a=Math.random()*6.283, rr=w.r*(0.9+Math.random()*0.25);
      addSpark(w.x+Math.cos(a)*rr,w.y+Math.sin(a)*rr);
    }
  }

  // trail veil
  ctx.fillStyle='rgba(5,6,12,0.052)';ctx.fillRect(0,0,W,H);
  if(bloom>0.001){ ctx.fillStyle=`rgba(232,182,87,${bloom*0.05})`;ctx.fillRect(0,0,W,H);bloom*=0.94; }
  if(wholeGlow>0.004){
    const grd=ctx.createRadialGradient(W/2,H/2,0,W/2,H/2,Math.max(W,H)*0.72);
    grd.addColorStop(0,`rgba(246,228,184,${0.12*wholeGlow})`);
    grd.addColorStop(1,'rgba(246,228,184,0)');
    ctx.fillStyle=grd;ctx.fillRect(0,0,W,H);
  }
  ctx.globalCompositeOperation='lighter';

  // flowing light tracing the rim of absence
  for(let i=0;i<N;i++){
    const p=P[i];
    const ang=noise(p.x*NS,p.y*NS+t*TS*0.01)*Math.PI*3.2;
    let vx=Math.cos(ang)*p.spd, vy=Math.sin(ang)*p.spd, glow=0;
    for(const w of wells){
      const dx=p.x-w.x,dy=p.y-w.y,d=Math.hypot(dx,dy)+0.001;
      if(d<w.r*2.2){
        const f=1-d/(w.r*2.2),push=f*f*3.4;
        vx+=dx/d*push;vy+=dy/d*push;
        vx+=-dy/d*f*0.9;vy+=dx/d*f*0.9;
        if(d<w.r*1.25)glow=Math.max(glow,1-Math.abs(d-w.r)/(w.r*0.5));
      }
    }
    p.px=p.x;p.py=p.y;p.x+=vx;p.y+=vy;p.age++;
    if(p.x<-20)p.x=W+20;if(p.x>W+20)p.x=-20;if(p.y<-20)p.y=H+20;if(p.y>H+20)p.y=-20;
    if(p.age>p.span){spawn(p);continue;}
    const a=Math.min(1,p.age/24)*Math.min(1,(p.span-p.age)/40)*0.5*(0.35+glow*0.95);
    if(a<=0.004)continue;
    const g=Math.round(150+p.warm*78+glow*22), b=Math.round(70+p.warm*70+glow*120);
    ctx.strokeStyle=`rgba(${232+(p.warm<0.18?8:18)},${g},${b},${a})`;
    ctx.lineWidth=0.62+glow*0.9;
    ctx.beginPath();ctx.moveTo(p.px,p.py);ctx.lineTo(p.x,p.y);ctx.stroke();
  }

  // scattered sparks — drifting, awaiting tikun
  let gathered=0;
  const mending = mode==='mend' && pointer.active;
  for(let i=sparks.length-1;i>=0;i--){
    const s=sparks[i];s.age++;
    const ang=noise(s.x*NS*1.4,s.y*NS*1.4+t*TS*0.012)*6.283;
    s.vx+=Math.cos(ang)*0.04; s.vy+=Math.sin(ang)*0.04;
    if(mending){
      const dx=pointer.x-s.x,dy=pointer.y-s.y,d=Math.hypot(dx,dy)+0.001;
      if(d<260){ const pull=(1-d/260)*0.9; s.vx+=dx/d*pull; s.vy+=dy/d*pull; }
      if(d<16){ sparks.splice(i,1); gathered++; bloom=Math.min(1,bloom+0.18);
        // gentle gathering ring
        ctx.strokeStyle='rgba(246,228,184,0.5)';ctx.lineWidth=1;
        ctx.beginPath();ctx.arc(pointer.x,pointer.y,10+Math.random()*8,0,6.283);ctx.stroke();
        continue; }
    }
    s.vx*=0.95;s.vy*=0.95;s.x+=s.vx;s.y+=s.vy;
    if(s.x<0||s.x>W||s.y<0||s.y>H||s.age>s.span){sparks.splice(i,1);continue;}
    const flick=0.7+0.3*Math.sin(s.age*0.2+i);
    const fadeOut=Math.min(1,(s.span-s.age)/200);
    const a=s.a*flick*fadeOut;
    ctx.fillStyle=`rgba(246,228,184,${a*0.85})`;
    ctx.beginPath();ctx.arc(s.x,s.y,0.95,0,6.283);ctx.fill();
  }

  // mending closes the vessels: redeemed light returns to fullness
  if(mending){
    ctx.strokeStyle='rgba(232,182,87,0.22)';ctx.lineWidth=1;
    ctx.beginPath();ctx.arc(pointer.x,pointer.y,46+4*Math.sin(t*0.1),0,6.283);ctx.stroke();
    if(gathered>0 || t%2===0){
      let near=null,nd=1e9;
      for(const w of wells){const d=Math.hypot(w.x-pointer.x,w.y-pointer.y);if(d<nd){nd=d;near=w;}}
      if(near && nd<near.r*3){ near.r0*=0.985;
        if(near.r0<8){wells.splice(wells.indexOf(near),1);bloom=Math.min(1,bloom+0.3);} }
    }
    if(gathered>0) swell(gathered);
  }

  // wholeness restored (ein sof) — the cycle reaches rest
  if(!whole && wells.length===0 && sparks.length<8){
    whole=true; bloom=Math.min(1,bloom+0.6);
    glossEl.style.opacity=0;
    setTimeout(()=>{glossEl.innerHTML=texts.whole;glossEl.style.opacity=1;},300);
  }

  ctx.globalCompositeOperation='source-over';
  requestAnimationFrame(step);
}
step();

/* ---- interaction ---- */
function act(x,y){
  pointer.x=x;pointer.y=y;
  if(mode==='withdraw'){
    if(whole){whole=false;glossEl.innerHTML=texts.withdraw;}
    const now=performance.now();
    if(now-lastWell>110){ lastWell=now;
      seedWell(x,y,Math.min(W,H)*(0.05+Math.random()*0.06));
      if(wells.length>9)wells.shift();
    }
  }
}
cv.addEventListener('pointerdown',e=>{pointer.active=true;act(e.clientX,e.clientY);});
cv.addEventListener('pointermove',e=>{pointer.x=e.clientX;pointer.y=e.clientY;if(pointer.active)act(e.clientX,e.clientY);});
addEventListener('pointerup',()=>pointer.active=false);
addEventListener('pointercancel',()=>pointer.active=false);

const glossEl=document.getElementById('gloss');
const texts={
  withdraw:'Najpierw światło się <em>wycofuje</em>. Tam, gdzie dotkniesz, otwiera się pustka — i dopiero ona nadaje kształt temu, co widać.',
  mend:'Z pękniętych naczyń sypią się iskry. Zbierz je <em>dłonią światła</em> — pustka domyka się, a blask wraca do pełni.',
  whole:'אין סוף · <em>pełnia</em> — niczego nie brakuje, nic nie zbywa. A gdy zechcesz, krąg zaczyna się od nowa.'
};
function setMode(m){
  mode=m;
  document.getElementById('mWith').classList.toggle('on',m==='withdraw');
  document.getElementById('mMend').classList.toggle('on',m==='mend');
  cv.style.cursor = m==='mend' ? 'cell' : 'crosshair';
  glossEl.style.opacity=0;
  setTimeout(()=>{glossEl.innerHTML=texts[m];glossEl.style.opacity=1;},300);
}
document.getElementById('mWith').onclick=()=>setMode('withdraw');
document.getElementById('mMend').onclick=()=>setMode('mend');
document.getElementById('reseed').onclick=()=>{autoSeed();glossEl.style.opacity=0;
  setTimeout(()=>{glossEl.innerHTML=texts[mode];glossEl.style.opacity=1;},300);};

/* ---- opt-in generative drone ---- */
let audio=null,masterGain=null,swellGain=null;
function swell(n){ if(swellGain){const g=swellGain.gain;const now=audio.currentTime;
  g.cancelScheduledValues(now);g.setValueAtTime(g.value,now);
  g.linearRampToValueAtTime(Math.min(0.05,g.value+0.012*n),now+0.05);
  g.linearRampToValueAtTime(0,now+2.4);} }
const sndBtn=document.getElementById('snd');
sndBtn.onclick=()=>{
  if(!audio){
    audio=new (window.AudioContext||window.webkitAudioContext)();
    masterGain=audio.createGain();masterGain.gain.value=0;
    const lp=audio.createBiquadFilter();lp.type='lowpass';lp.frequency.value=620;lp.Q.value=0.7;
    masterGain.connect(lp);lp.connect(audio.destination);
    // drone — open fifth + octave, slightly detuned
    [73.42,110,164.81].forEach((f,i)=>{
      const o=audio.createOscillator();o.type=i===2?'triangle':'sine';
      o.frequency.value=f;o.detune.value=(i-1)*4;
      const g=audio.createGain();g.gain.value=i===2?0.18:0.32;
      o.connect(g);g.connect(masterGain);o.start();
    });
    const lfo=audio.createOscillator();lfo.frequency.value=0.05;
    const lfoG=audio.createGain();lfoG.gain.value=180;
    lfo.connect(lfoG);lfoG.connect(lp.frequency);lfo.start();
    swellGain=audio.createGain();swellGain.gain.value=0;
    const ping=audio.createOscillator();ping.type='sine';ping.frequency.value=329.63;
    ping.connect(swellGain);swellGain.connect(masterGain);ping.start();
  }
  const on=sndBtn.classList.toggle('live');
  if(audio.state==='suspended')audio.resume();
  const now=audio.currentTime;
  masterGain.gain.cancelScheduledValues(now);
  masterGain.gain.linearRampToValueAtTime(on?0.13:0,now+(on?2.5:1.2));
  sndBtn.textContent = on ? '♪ cisza' : '♪ dźwięk';
};
</script>
</body>
</html>